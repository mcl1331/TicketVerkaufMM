@model TicketverkaufMM.ViewModels.ReservierungCreateViewModel

@{
    ViewData["Title"] = "Reservierung erstellen";
}

<h1>Reservierung erstellen</h1>

<form asp-action="Create" method="post" class="mt-4">

    <div class="mb-3">
        <label asp-for="Personenanzahl" class="form-label"></label>
        <input asp-for="Personenanzahl" class="form-control" />
        <span asp-validation-for="Personenanzahl" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TischId" class="form-label"></label>
        <select asp-for="TischId" class="form-select">
            <option value="">-- Tisch auswählen --</option>
            <option value="1">Tisch 1</option>
            <option value="2">Tisch 2</option>
            <option value="3">Tisch 3</option>
            <option value="4">Tisch 4</option>
        </select>
        <span asp-validation-for="TischId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EventName" class="form-label"></label>
        <input asp-for="EventName" class="form-control" />
        <span asp-validation-for="EventName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Datum" class="form-label"></label>
        <input asp-for="Datum" type="date" class="form-control" />
        <span asp-validation-for="Datum" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Speichern</button>
    <a asp-action="Index" class="btn btn-secondary">Zurück</a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}