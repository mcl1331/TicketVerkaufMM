@{
    ViewData["Title"] = "Home Page";
}

<div class="row align-items-center my-4 py-5 px-3 rounded-3"
     style="background-color: #1e1e1e;">

    <!-- Text links -->
    <div class="col-md-6">
        <h1 class="display-4 fw-bold text-white">Willkommen bei TicketVerkaufMM</h1>
        <p class="lead mt-3 text-secondary">
            Verpasse kein Event mehr! Reserviere deine Tickets bequem online –
            schnell, sicher und unkompliziert.
        </p>
        <a asp-controller="Reservierungs" asp-action="Create" class="btn btn-primary btn-lg mt-2">
            Jetzt reservieren
        </a>
    </div>

    <!-- Bild rechts -->
    <div class="col-md-6 text-center">
        <img src="~/Image.png" alt="Event"
             class="img-fluid rounded shadow"
             style="max-width: 50%;" />
    </div>

</div>